{
  "expo": {
    "name": "CricketFast Live Line",
    "slug": "cricketfast",
    "owner": "mybyess-team",
    "version": "1.0.0",
    "description": "Live cricket line — scores, session, squad, history & points table. Free, no login.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1b5e20"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cricketfast.live"
    },
    "android": {
      "package": "com.cricketfast.live",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1b5e20",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "permissions": ["INTERNET", "RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "CricketFast — Live Cricket Scores",
      "shortName": "CricketFast",
      "description": "Live cricket scores, scorecards and upcoming matches. No login required.",
      "themeColor": "#1b5e20",
      "backgroundColor": "#f0f2f0",
      "display": "standalone",
      "lang": "en",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#1b5e20",
          "icon": "./assets/icon.png"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3957cd95-ebb3-42f4-8c68-27148cefb64e"
      }
    }
  }
}

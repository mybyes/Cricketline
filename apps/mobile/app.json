{
  "expo": {
    "name": "LiveLine Guru",
    "slug": "cricketfast",
    "owner": "mybyess-team",
    "version": "1.0.0",
    "description": "Live cricket line — fast ball-by-ball scores, session & rates, scorecard, squads, fixtures & points table. Free, no login.",
    "scheme": "livelineguru",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.livelineguru.app"
    },
    "android": {
      "package": "com.livelineguru.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0a3f27",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "LiveLine Guru — Live Cricket Scores",
      "shortName": "LiveLine Guru",
      "description": "Live cricket scores, scorecards and upcoming matches. No login required.",
      "themeColor": "#0a3f27",
      "backgroundColor": "#f0f2f0",
      "display": "standalone",
      "lang": "en",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#0a3f27",
          "icon": "./assets/icon.png"
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0a3f27"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "3957cd95-ebb3-42f4-8c68-27148cefb64e"
      }
    }
  }
}

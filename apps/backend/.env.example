# Single key (legacy) — still supported.
CRICAPI_KEY=your_cricapi_key_here
# Optional: comma-separated key pool. The backend rotates to the next key when one
# hits its daily quota, multiplying the free tier and giving a fallback source.
# Exhausted keys are parked until the next UTC midnight (when CricAPI resets).
# CRICAPI_KEYS=key_one_here,key_two_here
UPSTASH_REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://cricketfast:cricketfast@localhost:5432/cricketfast
PORT=3000

# Production: comma-separated allowed CORS origins. Unset = allow all (dev/demo).
# ALLOWED_ORIGINS=https://cricketfastliveline.in,https://www.cricketfastliveline.in

# Secondary data source — unofficial Cricbuzz on RapidAPI. When set, used as a
# fallback when CricAPI is empty/over quota. Subscribe (free tier) at rapidapi.com.
# RAPIDAPI_KEY=your_rapidapi_key_here
# RAPIDAPI_CRICBUZZ_HOST=cricbuzz-cricket.p.rapidapi.com

# User comments feature toggle (default on). Set to 0 to disable site-wide.
# COMMENTS_ENABLED=1

# Demo mode — serve the built-in dataset (live matches, scorecards, ball-by-ball)
# instead of calling CricAPI. Lets the whole app run with no key. Also auto-enables
# when no CRICAPI_KEY/CRICAPI_KEYS is set. Set to 0 (or remove) + add a key for live data.
SEED_DATA=1
